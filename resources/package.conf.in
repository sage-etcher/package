#!/usr/bin/env bash

PACKAGE_LIB='@LIBDIR@/libpackage.sh'
DATABASE='@VARDIR@/db/package/package.db'
PROTECTED_FOLDERS_FILE='/etc/package/protected_folders'

BINDIR='@BINDIR@'

ROOT_PATH='/'
CHECKSUM_PROG=md5sum

# 0 fatal errors only
# 1 error and above
# 2 warnings
# 3 info/terse
# 4 verbose
# 5 debug
LOG_LEVEL=4

export PACKAGE_LIB DATABASE ROOT_PATH BINDIR LOG_LEVEL

# end of file
